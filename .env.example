# ════════════════════════════════════════════════════
# دليلك Backend — نموذج المتغيرات البيئية
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
#   cp .env.example .env
# ════════════════════════════════════════════════════

# ─── الخادم ───
PORT=5000
NODE_ENV=development
# عنوان السيرفر (مهم لـ Keep-Alive على Render)
BACKEND_URL=http://localhost:5000

# ─── JWT (لا يقل عن 32 حرفاً — استخدم قيمة عشوائية قوية) ───
# توليد قيمة: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_chars

# ─── MongoDB ───
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/dalilak
# محلي:  mongodb://localhost:27017/dalilak
MONGO_URI=mongodb://localhost:27017/dalilak

# ─── CORS — عناوين الفرونتند المسموحة (افصل بفاصلة) ───
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Google Places API (اختياري) ───
GOOGLE_API_KEY=your_google_api_key_here

# ─── ZainCash (اختياري — للاشتراكات المدفوعة) ───
ZAINCASH_MSISDN=your_zaincash_msisdn
ZAINCASH_MERCHANT=your_merchant_id
ZAINCASH_SECRET=your_secret_key
ZAINCASH_REDIRECT=http://localhost:5000/api/payment/callback
